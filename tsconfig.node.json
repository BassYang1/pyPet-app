{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",          // Node 环境使用 "node"
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "lib": ["ES2020"],
    "types": ["node"],
    "emitDeclarationOnly": true,         // 满足 composite 要求，只生成 .d.ts
    "outDir": "node_modules/.cache/tsc"  // 临时输出目录，不污染源码
  },
  "include": ["vite.config.ts"],
  "exclude": ["node_modules"]
}